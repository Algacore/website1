---
import SectionHead from "@/components/SectionHead.astro";
import Roadmap from "@/components/react/Roadmap.tsx";
import type { SiteContent } from "@/lib/content";
interface Props {
  path: SiteContent["path"];
}
const { path } = Astro.props;
---

<section id="path" class="section-pad section-alt relative">
  <div class="container">
    <SectionHead chapter="04" eyebrow={path.eyebrow} title={path.title} />

    <div class="reveal">
      <Roadmap client:visible steps={path.steps} />
    </div>
  </div>
</section>
