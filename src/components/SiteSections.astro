---
import { getContent } from "@/lib/content";
import type { Lang } from "@/i18n/config";
import Hero from "@/components/sections/Hero.astro";
import Band from "@/components/sections/Band.astro";
import Vision from "@/components/sections/Vision.astro";
import Market from "@/components/sections/Market.astro";
import Approach from "@/components/sections/Approach.astro";
import Science from "@/components/sections/Science.astro";
import Path from "@/components/sections/Path.astro";
import Team from "@/components/sections/Team.astro";
import Connect from "@/components/sections/Connect.astro";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const c = getContent(lang);
---

<Hero hero={c.hero} />
<Band band={c.band} />
<Vision vision={c.vision} />
<Market market={c.market} />
<Approach approach={c.approach} />
<Science science={c.science} />
<Path path={c.path} />
<Team team={c.team} />
<Connect connect={c.connect} form={c.form} lang={lang} />
