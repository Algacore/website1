---
import "@/styles/global.css";
import { getContent } from "@/lib/content";
import { localeAttr, homePath, type Lang } from "@/i18n/config";
import MarkDefs from "@/components/MarkDefs.astro";
import Footer from "@/components/Footer.astro";
import Nav from "@/components/react/Nav.tsx";
import SiteEffects from "@/components/react/SiteEffects.tsx";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const c = getContent(lang);
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
const altLang = lang === "pt" ? "en" : "pt";
const origin = Astro.site ?? new URL(Astro.url.origin);
const absHome = (l: Lang) => new URL(homePath(l), origin).toString();
---

<!doctype html>
<html lang={localeAttr[lang]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{c.meta.title}</title>
    <meta name="description" content={c.meta.desc} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="pt-BR" href={absHome("pt")} />
    <link rel="alternate" hreflang="en" href={absHome("en")} />
    <link rel="alternate" hreflang="x-default" href={absHome("pt")} />

    <!-- Type system: Outfit (body/UI/wordmark) + Fraunces (serif display). -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..500&family=Outfit:wght@300;400;500;600;700&display=swap"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Social -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Algacore" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={c.meta.title} />
    <meta property="og:description" content={c.meta.desc} />
    <meta property="og:locale" content={localeAttr[lang].replace("-", "_")} />
    <meta property="og:locale:alternate" content={localeAttr[altLang].replace("-", "_")} />
    <meta property="og:image" content="https://algacore.com.br/brand/og/og-card.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Algacore" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={c.meta.title} />
    <meta name="twitter:description" content={c.meta.desc} />
    <meta name="twitter:image" content="https://algacore.com.br/brand/og/og-card.png" />
    <meta name="twitter:image:alt" content="Algacore" />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify([
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Algacore",
        "alternateName": ["Alga Core", "Core Alga", "AlgaCore", "Algacore Biotecnologia", "Algacore Ficocianina"],
        "legalName": "ALGACORE Biotecnologia Ltda",
        "url": "https://algacore.com.br",
        "logo": "https://algacore.com.br/brand/square/algacore-logo-square.png",
        "description": lang === "pt"
          ? "Fornecedor B2B de ficocianina de alto grau, cultivada em fotobiorreatores fechados no Brasil, rumo ao padrão farmacêutico."
          : "B2B supplier of high-grade phycocyanin cultivated in closed photobioreactors in Brazil, building toward a pharmaceutical standard.",
        "email": "contato@algacore.com.br",
        "foundingDate": "2024",
        "areaServed": ["BR", "LATAM"],
        "knowsAbout": ["phycocyanin", "spirulina", "photobioreactor", "ficocianina", "biotechnology"],
        "sameAs": []
      },
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Algacore",
        "alternateName": ["Alga Core", "Core Alga", "Algacore Ficocianina"],
        "url": "https://algacore.com.br"
      },
      {
        "@context": "https://schema.org",
        "@type": "Service",
        "name": lang === "pt" ? "Ficocianina de alto grau B2B" : "High-grade phycocyanin B2B supply",
        "provider": { "@type": "Organization", "name": "Algacore" },
        "description": lang === "pt"
          ? "Fornecimento B2B de ficocianina rastreável extraída de spirulina cultivada em fotobiorreatores fechados, em escala industrial no Brasil."
          : "B2B supply of traceable phycocyanin extracted from spirulina cultivated in closed photobioreactors at industrial scale in Brazil.",
        "areaServed": "BR",
        "serviceType": lang === "pt" ? "Ingrediente biotecnológico B2B" : "B2B biotechnology ingredient"
      }
    ])} />

    <!-- Mark the document JS-capable before first paint so scroll-reveal styles
         only apply when JS can drive them (no hidden content without JS). -->
    <script is:inline>document.documentElement.classList.add("js");</script>
  </head>
  <body>
    <div class="scroll-progress" aria-hidden="true"></div>
    <a class="skip-link" href="#vision">{c.a11y.skip}</a>

    <MarkDefs />

    <Nav
      client:load
      lang={lang}
      navTeam={c.nav.team}
      navContact={c.nav.contact}
      langLabel={c.langToggleLabel}
      ptHref={homePath("pt")}
      enHref={homePath("en")}
    />

    <main>
      <slot />
    </main>

    <Footer copy={c.footer.copy} mail={c.footer.mail} />

    <SiteEffects client:load />
  </body>
</html>
